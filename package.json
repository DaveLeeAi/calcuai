{
  "name": "calculator-authority-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run generate:registry",
    "build": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "validate": "npx ts-node --project tsconfig.scripts.json scripts/validate-content.ts",
    "check-dupes": "npx ts-node --project tsconfig.scripts.json scripts/check-duplicates.ts",
    "audit-links": "npx ts-node --project tsconfig.scripts.json scripts/audit-links.ts",
    "score": "npx ts-node --project tsconfig.scripts.json scripts/score-calculators.ts",
    "qa": "npm run validate && npm run check-dupes && npm run audit-links && npm run test:formulas && npm run score",
    "generate": "npx ts-node --project tsconfig.scripts.json scripts/generate-calculator.ts",
    "generate:registry": "npx ts-node --project tsconfig.scripts.json scripts/generate-formula-registry.ts",
    "test": "jest",
    "test:formulas": "jest --testPathPattern=formulas"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "clsx": "^2.1.0",
    "d3-geo": "^3.1.1",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.0",
    "next": "^14.2.0",
    "next-mdx-remote": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/katex": "^0.16.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "glob": "^10.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
