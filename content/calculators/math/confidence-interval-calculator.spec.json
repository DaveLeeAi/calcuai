      "placeholder": "e.g. 25",
      "helpText": "The number of observations in your sample"
    },
    {
      "id": "confidenceLevel",
      "label": "Confidence Level (%)",
      "type": "select",
      "required": true,
      "defaultValue": "95",
      "options": [
        { "value": "80", "label": "80%" },
        { "value": "85", "label": "85%" },
        { "value": "90", "label": "90%" },
        { "value": "95", "label": "95%" },
        { "value": "99", "label": "99%" },
        { "value": "99.9", "label": "99.9%" }
      ],
      "helpText": "Higher confidence levels produce wider intervals"
    }
