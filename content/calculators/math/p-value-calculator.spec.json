      "min": 1,
      "max": 10000,
      "step": 1,
      "placeholder": "e.g. 10",
      "helpText": "Required for t-test and chi-square. Not used for z-test."
    },
    {
      "id": "testType",
      "label": "Test Type",
      "type": "radio",
      "required": true,
      "defaultValue": "two-tailed",
      "options": [
