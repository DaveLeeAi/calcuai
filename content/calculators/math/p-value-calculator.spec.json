        { "value": "right-tailed", "label": "Right-Tailed (Upper)" },
        { "value": "left-tailed", "label": "Left-Tailed (Lower)" }
      ],
      "helpText": "Two-tailed tests for any difference; one-tailed tests for a specific direction."
    }
  ],
  "outputs": [
