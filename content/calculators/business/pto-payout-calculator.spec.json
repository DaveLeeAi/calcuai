{
  "id": "pto-payout-calculator",
  "title": "PTO Payout Calculator",
  "slug": "pto-payout-calculator",
  "category": "business",
  "subcategory": "payroll",
  "primaryKeyword": "PTO payout calculator",
  "metaTitle": "PTO Payout Calculator | Calculate Your Accrued Vacation Value",
  "metaDescription": "Calculate how much your accrued PTO is worth. See gross payout, estimated taxes, and net amount for unused vacation, sick, and personal days.",
  "inputs": [
    {
      "id": "hourlyRate",
      "label": "Hourly Rate",
      "type": "currency",
      "required": true,
      "defaultValue": 25,
      "min": 0,
      "max": 10000,
      "step": 0.25,
      "prefix": "$",
      "helpText": "Your hourly pay rate — if salaried, divide annual salary by 2,080"
    },
    {
      "id": "accruedHours",
      "label": "Accrued PTO Hours",
      "type": "number",
      "required": true,
      "defaultValue": 80,
      "min": 0,
      "max": 500,
      "step": 1,
      "helpText": "Total PTO hours accrued"
    },
    {
      "id": "accruedDays",
      "label": "Accrued PTO Days",
      "type": "number",
      "required": true,
      "defaultValue": 0,
      "min": 0,
      "max": 60,
      "step": 0.5,
      "helpText": "Additional PTO days accrued (converted to hours at your work-day length)"
    },
    {
      "id": "hoursPerDay",
      "label": "Hours per Work Day",
      "type": "number",
      "required": true,
      "defaultValue": 8,
      "min": 4,
      "max": 12,
      "step": 0.5,
      "helpText": "Hours in your standard work day"
    },
    {
      "id": "taxRate",
      "label": "Tax Withholding Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 22,
      "min": 0,
      "max": 50,
      "step": 1,
      "suffix": "%",
      "helpText": "Estimated tax withholding rate"
    },
    {
      "id": "ptoPolicy",
      "label": "PTO Payout Policy",
      "type": "select",
      "required": true,
      "defaultValue": "full-payout",
      "options": [
        {
          "value": "full-payout",
          "label": "Full Payout (100%)"
        },
        {
          "value": "partial-payout",
          "label": "Partial Payout"
        },
        {
          "value": "use-it-or-lose-it",
          "label": "Use It or Lose It"
        }
      ],
      "helpText": "Your employer's PTO payout policy"
    },
    {
      "id": "payoutPercent",
      "label": "Payout Percentage",
      "type": "percentage",
      "required": true,
      "defaultValue": 100,
      "min": 0,
      "max": 100,
      "step": 5,
      "suffix": "%",
      "helpText": "Percentage of PTO paid out — for partial payout policies",
      "visibleWhen": {
        "ptoPolicy": [
          "partial-payout"
        ]
      }
    }
  ],
  "outputs": [
    {
      "id": "netPayout",
      "label": "Net PTO Payout",
      "type": "single-value",
      "format": "currency",
      "highlight": true
    },
    {
      "id": "grossPayout",
      "label": "Gross PTO Payout",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "taxWithholding",
      "label": "Tax Withholding",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "totalHours",
      "label": "Total PTO Hours",
      "type": "single-value",
      "format": "number"
    },
    {
      "id": "totalDays",
      "label": "Total PTO Days",
      "type": "single-value",
      "format": "number",
      "precision": 1
    },
    {
      "id": "dailyValue",
      "label": "Daily Value",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "weeklyValue",
      "label": "Weekly Value",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "totalWeeksOff",
      "label": "Weeks of Time Off",
      "type": "single-value",
      "format": "number",
      "precision": 1
    },
    {
      "id": "payoutBreakdown",
      "label": "Payout Breakdown",
      "type": "value-group",
      "format": "currency"
    }
  ],
