  "metaTitle": "Business Sales Tax Calculator — Merchant Tax Pricing Tool",
  "metaDescription": "Calculate sales tax for your business pricing. See tax-inclusive vs tax-exclusive strategies, monthly tax liability, and profit impact. Built for merchants.",
  "inputs": [
    {
      "id": "pricingStrategy",
      "label": "Pricing Strategy",
      "type": "select",
      "required": true,
      "defaultValue": "tax-exclusive",
      "options": [
        {
          "value": "tax-exclusive",
          "label": "Tax-Exclusive (tax added at checkout)"
        },
        {
          "value": "tax-inclusive",
          "label": "Tax-Inclusive (tax built into price)"
        }
      ],
      "helpText": "Choose how you display prices to customers"
    },
    {
      "id": "unitCost",
      "label": "Unit Cost",
      "type": "currency",
      "required": true,
      "defaultValue": 20,
      "min": 0,
      "max": 100000000,
      "step": 0.01,
      "prefix": "$",
      "helpText": "Your cost to produce or acquire the item"
    },
    {
      "id": "desiredMarginPercent",
      "label": "Desired Markup %",
      "type": "percentage",
      "required": true,
      "defaultValue": 40,
      "min": 0,
      "max": 10000,
      "step": 0.1,
      "helpText": "Target markup percentage over cost"
    },
    {
      "id": "taxRate",
      "label": "Sales Tax Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 8.25,
      "min": 0,
      "max": 25,
      "step": 0.01,
      "helpText": "Combined state + local sales tax rate"
    },
    {
      "id": "monthlySalesVolume",
      "label": "Monthly Sales Volume",
      "type": "number",
      "required": true,
      "defaultValue": 500,
      "min": 0,
      "max": 10000000,
      "step": 1,
      "helpText": "Average units sold per month"
    },
    {
      "id": "stickerPrice",
      "label": "Sticker Price (Tax-Inclusive)",
      "type": "currency",
      "required": false,
      "defaultValue": 50,
      "min": 0,
      "max": 100000000,
      "step": 0.01,
      "prefix": "$",
      "dependsOn": "pricingStrategy",
      "helpText": "The all-in price the customer sees (used in tax-inclusive mode)"
    }
  ],
