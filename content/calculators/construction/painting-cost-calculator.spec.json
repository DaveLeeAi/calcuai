        {
          "value": "sqm",
          "label": "Square Meters",
          "conversionFactor": 10.7639
        }
      ],
      "defaultUnit": "sqft",
      "helpText": "Total wall or surface area to paint — a typical room is 400-600 sq ft of wall area"
