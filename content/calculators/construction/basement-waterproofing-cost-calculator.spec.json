          "label": "Large - 1,000-1,500 sq ft"
        },
        {
          "value": "xlarge-over-1500",
          "label": "Extra Large - Over 1,500 sq ft"
        }
      ],
      "helpText": "Used to suggest default wall perimeter length if you do not enter a custom value below."
    },
    {
      "id": "method",
      "label": "Waterproofing Method",
      "type": "select",
      "required": true,
      "defaultValue": "interior-drainage",
      "options": [
        {
          "value": "interior-sealant",
          "label": "Interior Sealant (-/lf - surface coating)"
        },
        {
          "value": "interior-drainage",
          "label": "Interior Drainage (\u0000-\u0000/lf - French drain)"
        },
        {
          "value": "exterior-excavation",
          "label": "Exterior Excavation (\u0000-\u0000/lf - full dig)"
        },
        {
          "value": "combination",
          "label": "Combination (\u0000-(/lf - interior + exterior)"
        }
      ],
      "helpText": "Interior sealant is cheapest but only stops minor moisture. Exterior excavation is the gold standard for serious water intrusion. Combination addresses both sides of the wall."
    },
    {
      "id": "wallLength",
      "label": "Wall Length (Linear Feet)",
      "type": "number",
      "required": false,
      "defaultValue": 100,
      "min": 20,
      "max": 500,
      "helpText": "Total linear feet of basement wall to waterproof. Typical: 80 lf (small), 120 lf (medium), 150 lf (large), 180 lf (extra large). Measure perimeter of affected walls."
    },
    {
      "id": "crackRepair",
      "label": "Crack Repair",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Crack Repair Needed"
        },
        {
          "value": "minor",
          "label": "Minor Cracks (+(-\u0000)"
        },
        {
          "value": "major",
          "label": "Major Cracks (+,000-,000)"
        }
      ],
      "helpText": "Minor cracks are hairline or less than 1/4 inch. Major cracks are structural, wider than 1/4 inch, or actively leaking."
    },
    {
      "id": "sumpPump",
      "label": "Sump Pump",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Sump Pump"
        },
        {
          "value": "standard",
          "label": "Standard Sump Pump (+\u0000-,500)"
        },
        {
          "value": "battery-backup",
          "label": "Battery Backup Sump (+,000-,000)"
        }
      ],
      "helpText": "A sump pump collects water from the drainage system and pumps it away from the foundation. Battery backup ensures operation during power outages."
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
