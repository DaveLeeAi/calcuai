  "metaTitle": "EV Charger Installation Cost Calculator | Level 1 & 2",
  "metaDescription": "Estimate home EV charger installation costs for Level 1 and Level 2 (32A, 48A, 80A) chargers. Compare brand tiers, circuit distance, panel upgrades, and permits by region.",
  "inputs": [
    {
      "id": "chargerLevel",
      "label": "Charger Level",
      "type": "select",
      "required": true,
      "defaultValue": "level-2-32amp",
      "options": [
        {
          "value": "level-1",
          "label": "Level 1 — 120V (included EVSE, $0 charger)"
        },
        {
          "value": "level-2-32amp",
          "label": "Level 2 — 32A 240V ($300–$600)"
        },
        {
          "value": "level-2-48amp",
          "label": "Level 2 — 48A 240V ($500–$900)"
        },
        {
          "value": "level-2-80amp",
          "label": "Level 2 — 80A 240V ($700–$1,200)"
        }
      ],
      "helpText": "Level 1 uses a standard 120V outlet (3–5 mi/hr). Level 2 requires a dedicated 240V circuit and charges 6–12x faster."
    },
    {
      "id": "chargerBrand",
      "label": "Charger Brand Tier",
      "type": "select",
      "required": true,
      "defaultValue": "basic",
      "options": [
        {
          "value": "basic",
          "label": "Basic (1.0x — budget brands)"
        },
        {
          "value": "mid-range",
          "label": "Mid-Range (1.15x — ChargePoint, Grizzl-E)"
        },
        {
          "value": "premium",
          "label": "Premium (1.40x — JuiceBox, Wallbox)"
        },
        {
          "value": "tesla-wall-connector",
          "label": "Tesla Wall Connector (1.25x)"
        }
      ],
      "helpText": "Brand multiplier applied to charger hardware cost. Basic is the baseline."
    },
    {
      "id": "circuitDistance",
      "label": "Circuit Run Distance",
      "type": "select",
      "required": true,
      "defaultValue": "under-25ft",
      "options": [
        {
          "value": "under-25ft",
          "label": "Under 25 ft (1.0x labor)"
        },
        {
          "value": "25-50ft",
          "label": "25–50 ft (1.2x labor)"
        },
        {
          "value": "over-50ft",
          "label": "Over 50 ft (1.5x labor)"
        }
      ],
      "helpText": "Distance from electrical panel to charger location. Longer runs require more wire, conduit, and labor."
    },
    {
      "id": "panelUpgrade",
      "label": "Panel Upgrade",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Panel Upgrade Needed"
        },
        {
          "value": "subpanel",
          "label": "Add Subpanel (+$500–$1,500)"
        },
        {
          "value": "main-panel-upgrade",
          "label": "Main Panel Upgrade (+$1,500–$3,000)"
        }
      ],
      "helpText": "Older homes with 100A or 150A panels may need an upgrade to support a Level 2 charger. A subpanel is cheaper if the main panel has spare capacity."
    },
    {
      "id": "permitRequired",
      "label": "Permit Required?",
      "type": "select",
      "required": true,
      "defaultValue": "yes",
      "options": [
        {
          "value": "yes",
          "label": "Yes — Permit Needed (+$75–$250)"
        },
        {
          "value": "no",
          "label": "No Permit Needed"
        }
      ],
      "helpText": "Most jurisdictions require an electrical permit for 240V circuit installation. Check with your local building department."
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "defaultValue": "national",
      "options": [
        {
          "value": "national",
          "label": "National Average"
        },
        {
          "value": "northeast",
          "label": "Northeast (NY, NJ, CT, MA)"
        },
        {
          "value": "west-coast",
          "label": "West Coast (CA, WA, OR)"
        },
        {
          "value": "mid-atlantic",
          "label": "Mid-Atlantic (PA, MD, VA, DC)"
        },
        {
          "value": "midwest",
          "label": "Midwest (OH, IN, MI, WI)"
        },
        {
          "value": "south",
          "label": "South (TX, FL, GA, NC)"
        },
        {
          "value": "mountain-west",
          "label": "Mountain West (CO, AZ, UT)"
        }
      ],
      "helpText": "Adjusts labor costs for regional pricing differences"
    }
  ],
  "outputs": [
    {
      "id": "chargerCost",
      "label": "Charger Hardware (Mid)",
      "type": "single-value",
      "format": "currency",
      "precision": 0
    },
