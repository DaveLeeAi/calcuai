      "type": "value-group",
      "format": "currency"
    },
    {
      "id": "chargingSpeed",
      "label": "Charging Speed",
      "type": "single-value",
      "format": "string"
    },
    {
      "id": "timeline",
      "label": "Estimated Installation Time",
      "type": "single-value",
      "format": "string"
    }
  ],
