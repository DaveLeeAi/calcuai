        {
          "value": "dead-diseased",
          "label": "Dead / Diseased (1.15x — unpredictable)"
        },
        {
          "value": "storm-damaged",
          "label": "Storm Damaged (1.30x — hazardous)"
        }
      ],
      "helpText": "Dead, diseased, or storm-damaged trees are less predictable and require extra safety measures."
    },
