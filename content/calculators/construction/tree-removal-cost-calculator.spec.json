        {
          "value": "near-structure",
          "label": "Near Structure (1.25x — careful rigging)"
        },
        {
          "value": "near-power-lines",
          "label": "Near Power Lines (1.50x — utility coordination)"
        }
      ],
      "helpText": "Trees near buildings or power lines require crane work and careful sectional dismantling."
    },
    {
      "id": "stumpRemoval",
      "label": "Stump Removal",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Stump Removal"
        },
        {
          "value": "grinding",
          "label": "Stump Grinding (+$150–$400)"
        },
        {
          "value": "full-removal",
          "label": "Full Stump Removal (+$300–$700)"
        }
      ],
      "helpText": "Grinding shreds the stump 6-12 in below grade. Full removal extracts the root ball entirely."
    },
    {
      "id": "cleanup",
      "label": "Cleanup Option",
      "type": "select",
      "required": true,
