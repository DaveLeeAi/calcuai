        {
          "value": "xlarge-over-75ft",
          "label": "Extra Large — Over 75 ft ($2,500–$5,000)"
        }
      ],
      "helpText": "Measured from ground to crown. Taller trees require more equipment and crew time."
    },
    {
      "id": "trunkDiameter",
      "label": "Trunk Diameter",
      "type": "select",
      "required": true,
      "defaultValue": "thin-under-12in",
