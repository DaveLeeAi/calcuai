        {
          "value": "medium-12-24in",
          "label": "Medium — 12-24 in (1.20x)"
        },
        {
          "value": "thick-over-24in",
          "label": "Thick — Over 24 in (1.50x)"
        }
      ],
      "helpText": "Measured at chest height (DBH). Thicker trunks require heavier equipment and more labor."
    },
    {
      "id": "condition",
      "label": "Tree Condition",
      "type": "select",
      "required": true,
      "defaultValue": "healthy",
