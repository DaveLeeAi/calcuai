          "label": "Blown-In Cellulose ($1.50–$3.00/sq ft material)"
        },
        {
          "value": "spray-foam-open",
          "label": "Open-Cell Spray Foam ($2.50–$5.50/sq ft material)"
        },
        {
          "value": "spray-foam-closed",
          "label": "Closed-Cell Spray Foam ($4.00–$8.00/sq ft material)"
        },
        {
          "value": "rigid-board",
          "label": "Rigid Board ($2.00–$4.50/sq ft material)"
        },
        {
          "value": "mineral-wool",
          "label": "Mineral Wool ($3.00–$5.50/sq ft material)"
        }
      ],
