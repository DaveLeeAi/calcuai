          "value": "R-13",
          "label": "R-13 (walls, mild climate)"
        },
        {
          "value": "R-19",
          "label": "R-19 (walls, moderate climate)"
        },
        {
          "value": "R-30",
          "label": "R-30 (attic, standard)"
        },
        {
          "value": "R-38",
          "label": "R-38 (attic, cold climate)"
