  "metaTitle": "Whole House Generator Cost Calculator | Standby & Backup Estimates",
  "metaDescription": "Estimate whole-house backup generator costs for 7 kW to 48 kW units. Compare natural gas, propane, and diesel generators with transfer switch, pad, and permit add-ons by region.",
  "inputs": [
    {
      "id": "generatorSize",
      "label": "Generator Size",
      "type": "select",
      "required": true,
      "defaultValue": "large-20-24kw",
      "options": [
        { "value": "small-7-10kw", "label": "Small 7–10 kW ($2,500–$4,000)" },
        { "value": "medium-12-16kw", "label": "Medium 12–16 kW ($3,500–$6,000)" },
        { "value": "large-20-24kw", "label": "Large 20–24 kW ($5,000–$10,000)" },
        { "value": "xlarge-30-48kw", "label": "Extra-Large 30–48 kW ($10,000–$18,000)" }
      ],
      "helpText": "Small covers essential circuits (fridge, lights, sump). Medium covers most circuits. Large powers a whole home. Extra-large handles large or luxury homes with multiple HVAC systems."
    },
    {
      "id": "fuelType",
      "label": "Fuel Type",
      "type": "select",
      "required": true,
      "defaultValue": "natural-gas",
      "options": [
        { "value": "natural-gas", "label": "Natural Gas (1.0x — most common)" },
        { "value": "propane", "label": "Propane (1.05x — tank required)" },
        { "value": "diesel", "label": "Diesel (1.15x — longest runtime)" }
      ],
      "helpText": "Natural gas connects to your existing gas line. Propane requires a separate storage tank. Diesel generators cost more upfront but offer the longest runtime per gallon."
    },
    {
      "id": "transferSwitch",
      "label": "Transfer Switch",
      "type": "select",
      "required": true,
      "defaultValue": "automatic-whole-home",
      "options": [
        { "value": "manual", "label": "Manual ($300–$600)" },
        { "value": "automatic-load-shedding", "label": "Automatic Load-Shedding ($800–$1,500)" },
        { "value": "automatic-whole-home", "label": "Automatic Whole-Home ($1,500–$3,000)" }
      ],
      "helpText": "Manual requires you to physically switch over during an outage. Automatic load-shedding manages selected circuits. Automatic whole-home transfers all circuits instantly."
    },
    {
      "id": "pad",
      "label": "Generator Pad",
      "type": "select",
      "required": true,
      "defaultValue": "new-concrete-pad",
      "options": [
        { "value": "existing", "label": "Existing Pad (No Cost)" },
        { "value": "new-concrete-pad", "label": "New Concrete Pad ($300–$800)" }
      ],
      "helpText": "A level concrete pad is required for proper installation. If you already have a suitable pad, select existing."
    },
    {
      "id": "permitRequired",
      "label": "Permit Required?",
      "type": "select",
      "required": true,
      "defaultValue": "yes",
      "options": [
        { "value": "yes", "label": "Yes — Electrical/Building Permit ($100–$400)" },
        { "value": "no", "label": "No Permit Needed" }
      ],
      "helpText": "Most jurisdictions require an electrical permit and inspection for standby generator installation."
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "defaultValue": "national",
      "options": [
        { "value": "national", "label": "National Average" },
        { "value": "northeast", "label": "Northeast (NY, NJ, CT, MA)" },
        { "value": "west-coast", "label": "West Coast (CA, WA, OR)" },
        { "value": "mid-atlantic", "label": "Mid-Atlantic (PA, MD, VA, DC)" },
        { "value": "midwest", "label": "Midwest (OH, IN, MI, WI)" },
        { "value": "south", "label": "South (TX, FL, GA, NC)" },
        { "value": "mountain-west", "label": "Mountain West (CO, AZ, UT)" }
      ],
      "helpText": "Adjusts labor costs for regional pricing differences"
