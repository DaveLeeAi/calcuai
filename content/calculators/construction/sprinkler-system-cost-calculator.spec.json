  "metaTitle": "Sprinkler System Cost Calculator | In-Ground, Drip & Above-Ground Estimates",
  "metaDescription": "Estimate sprinkler system installation costs for above-ground, in-ground manual, in-ground automatic, and drip irrigation. Compare costs by lawn size, zone count, soil type, and region.",
  "inputs": [
    {
      "id": "lawnSize",
      "label": "Lawn Size",
      "type": "select",
      "required": true,
      "defaultValue": "medium-2500-5000",
      "options": [
        {
          "value": "small-under-2500",
          "label": "Small — Under 2,500 sq ft ($1,500–$2,500)"
        },
        {
          "value": "medium-2500-5000",
          "label": "Medium — 2,500–5,000 sq ft ($2,500–$4,500)"
        },
        {
          "value": "large-5000-10000",
          "label": "Large — 5,000–10,000 sq ft ($4,500–$7,500)"
        },
        {
          "value": "xlarge-over-10000",
          "label": "Extra Large — Over 10,000 sq ft ($7,500–$12,000)"
        }
      ],
      "helpText": "Total irrigated lawn area in square feet. Larger lawns require more zones and piping."
    },
    {
      "id": "systemType",
      "label": "System Type",
      "type": "select",
      "required": true,
      "defaultValue": "in-ground-automatic",
      "options": [
        {
          "value": "above-ground",
          "label": "Above-Ground (0.40x — portable hoses)"
        },
        {
          "value": "in-ground-manual",
          "label": "In-Ground Manual (0.85x — manual valves)"
        },
        {
          "value": "in-ground-automatic",
          "label": "In-Ground Automatic (1.0x — timer + valves)"
        },
        {
          "value": "drip-irrigation",
          "label": "Drip Irrigation (0.70x — garden beds)"
        }
      ],
      "helpText": "In-ground automatic is the most common residential system. Drip irrigation is best for garden beds and shrubs."
    },
    {
      "id": "zones",
      "label": "Number of Zones",
      "type": "number",
      "required": true,
      "defaultValue": 4,
      "min": 1,
      "max": 12,
      "helpText": "Each zone covers 800–1,200 sq ft. Small lawns need 3, medium 4, large 6, extra large 8+. Extra zones beyond included add $200–$400 each."
    },
    {
      "id": "soilType",
      "label": "Soil Type",
      "type": "select",
      "required": true,
      "defaultValue": "normal",
      "options": [
        {
          "value": "normal",
          "label": "Normal Soil (1.0x)"
        },
        {
          "value": "clay",
          "label": "Clay Soil (+15% labor)"
        },
        {
          "value": "rocky",
          "label": "Rocky Soil (+30% labor)"
        }
      ],
      "helpText": "Clay and rocky soil increase trenching labor. Rocky soil may require equipment upgrades."
    },
    {
      "id": "backflowPreventer",
      "label": "Backflow Preventer",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Backflow Preventer"
        },
        {
          "value": "standard",
          "label": "Standard (+$100–$300)"
        },
        {
          "value": "rpz-valve",
          "label": "RPZ Valve (+$300–$600 — code required)"
        }
      ],
      "helpText": "Many municipalities require a backflow preventer on irrigation systems to protect the water supply. RPZ valves are the highest-rated option."
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "defaultValue": "national",
      "options": [
