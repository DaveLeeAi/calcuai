        },
        {
          "value": "drain-tile-suction",
          "label": "Drain Tile Suction — Existing drain tile (1.25x)"
        },
        {
          "value": "block-wall-suction",
          "label": "Block Wall Suction — CMU foundations (1.15x)"
        },
        {
          "value": "heat-recovery-ventilator",
          "label": "Heat Recovery Ventilator (HRV) — Tight houses (1.75x)"
        }
      ],
      "helpText": "Sub-slab depressurization is the EPA-recommended method for most slab and basement homes. HRV systems are used when depressurization methods are impractical."
