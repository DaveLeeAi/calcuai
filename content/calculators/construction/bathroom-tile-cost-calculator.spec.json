      "step": 1,
      "helpText": "Total tile area in sq ft — or use default for selected project type"
    },
    {
      "id": "tileType",
      "label": "Tile Type",
      "type": "select",
      "required": true,
      "defaultValue": "ceramic",
      "options": [
        {
          "value": "ceramic",
          "label": "Ceramic ($10–$20/sq ft installed)"
        },
        {
          "value": "porcelain",
          "label": "Porcelain ($12–$25/sq ft installed)"
        },
        {
          "value": "natural-stone",
          "label": "Natural Stone ($20–$40/sq ft installed)"
        },
        {
          "value": "glass",
          "label": "Glass ($18–$35/sq ft installed)"
        },
        {
          "value": "large-format",
          "label": "Large-Format ($15–$30/sq ft installed)"
        }
      ],
      "helpText": "Tile material — each has different cost, durability, and maintenance needs"
    },
    {
      "id": "demoOldTile",
      "label": "Remove Old Tile?",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "No Demolition Needed"
        },
        {
          "value": "yes",
          "label": "Yes — Remove Existing ($4–$8/sq ft)"
        }
      ],
      "helpText": "Removing old tile adds $4–$8 per square foot for demolition and disposal"
    },
    {
      "id": "waterproofing",
      "label": "Waterproofing",
      "type": "select",
      "required": true,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "None (dry areas only)"
        },
        {
          "value": "standard",
          "label": "Standard ($2–$4/sq ft)"
        },
        {
          "value": "premium",
          "label": "Premium — Schluter/Kerdi ($4–$7/sq ft)"
        }
      ],
      "helpText": "Waterproofing membrane for wet areas — standard liquid-applied or premium sheet systems"
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor (%)",
      "type": "number",
      "required": true,
      "defaultValue": 10,
      "min": 5,
      "max": 25,
      "step": 1,
      "helpText": "Extra material for cuts and breakage — 10% standard, 15% for diagonal patterns"
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "defaultValue": "national",
      "options": [
        { "value": "national", "label": "National Average" },
        { "value": "northeast", "label": "Northeast (NY, NJ, CT, MA)" },
        { "value": "west-coast", "label": "West Coast (CA, WA, OR)" },
        { "value": "mid-atlantic", "label": "Mid-Atlantic (PA, MD, VA, DC)" },
        { "value": "midwest", "label": "Midwest (OH, IN, MI, WI)" },
        { "value": "south", "label": "South (TX, FL, GA, NC)" },
        { "value": "mountain-west", "label": "Mountain West (CO, AZ, UT)" }
      ],
      "helpText": "Adjusts labor costs for regional pricing differences"
    }
  ],
