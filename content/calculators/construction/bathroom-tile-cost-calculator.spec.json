      "id": "projectType",
      "label": "Project Type",
      "type": "select",
      "required": true,
      "defaultValue": "shower-walls",
      "options": [
        {
          "value": "shower-walls",
          "label": "Shower Walls (~80 sq ft)"
        },
        {
          "value": "shower-floor",
          "label": "Shower Floor (~15 sq ft)"
        },
        {
          "value": "bathroom-floor",
          "label": "Bathroom Floor (~50 sq ft)"
