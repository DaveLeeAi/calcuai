  "metaTitle": "Electrical Service Upgrade Cost Calculator | 100A to 200A & 400A",
  "metaDescription": "Estimate electrical service upgrade costs for 100 to 200 amp, 200 to 400 amp, and 100 to 400 amp projects. Includes meter relocation, underground conversion, home age factors, and regional labor pricing.",
  "inputs": [
    {
      "id": "upgradeType",
      "label": "Upgrade Type",
      "type": "select",
      "required": true,
      "defaultValue": "100-to-200",
      "options": [
        { "value": "100-to-200", "label": "100A to 200A ($3,000–$5,000)" },
