        { "value": "100-to-400", "label": "100A to 400A ($7,000–$14,000)" }
      ],
      "helpText": "A service upgrade replaces the utility meter base, weatherhead/mast, main service cable, AND main breaker panel. This is more extensive than a panel-only swap."
    },
    {
      "id": "meterLocation",
      "label": "Meter Location",
      "type": "select",
      "required": true,
      "defaultValue": "same-location",
      "options": [
