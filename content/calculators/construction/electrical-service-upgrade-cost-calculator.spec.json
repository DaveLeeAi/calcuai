        { "value": "relocate", "label": "Relocate Meter (+20% labor)" }
      ],
      "helpText": "Relocating the meter requires new conduit runs, trenching, and additional utility coordination."
    },
    {
      "id": "weatherhead",
      "label": "Service Entrance Type",
      "type": "select",
      "required": true,
      "defaultValue": "standard",
      "options": [
        { "value": "standard", "label": "Standard Overhead Weatherhead (1.0x)" },
        { "value": "underground-conversion", "label": "Underground Conversion (+30% labor)" }
      ],
      "helpText": "Converting from overhead to underground service adds trenching and conduit work but eliminates the exposed weatherhead and mast."
    },
    {
      "id": "homeAge",
      "label": "Home Age",
      "type": "select",
      "required": true,
      "defaultValue": "modern-post-2000",
      "options": [
        { "value": "modern-post-2000", "label": "Modern — Built After 2000 (1.0x)" },
        { "value": "mid-1960-2000", "label": "Mid-Century — 1960–2000 (+10% labor)" },
        { "value": "old-pre-1960", "label": "Older Home — Pre-1960 (+25% labor)" }
      ],
      "helpText": "Older homes often have outdated wiring, non-standard configurations, or asbestos-containing materials that increase labor time and complexity."
    },
    {
      "id": "permitRequired",
      "label": "Permit Required?",
      "type": "select",
      "required": true,
      "defaultValue": "yes",
      "options": [
        { "value": "yes", "label": "Yes — Electrical Permit ($200–$600)" },
        { "value": "no", "label": "No Permit Needed" }
      ],
      "helpText": "Electrical service upgrades require a permit and inspection in virtually all U.S. jurisdictions. The utility company also requires a permit before reconnecting service."
    },
    {
      "id": "region",
      "label": "Region",
      "type": "select",
      "required": true,
      "defaultValue": "national",
      "options": [
        { "value": "national", "label": "National Average" },
        { "value": "northeast", "label": "Northeast (NY, NJ, CT, MA)" },
        { "value": "west-coast", "label": "West Coast (CA, WA, OR)" },
        { "value": "mid-atlantic", "label": "Mid-Atlantic (PA, MD, VA, DC)" },
        { "value": "midwest", "label": "Midwest (OH, IN, MI, WI)" },
        { "value": "south", "label": "South (TX, FL, GA, NC)" },
        { "value": "mountain-west", "label": "Mountain West (CO, AZ, UT)" }
      ],
      "helpText": "Adjusts labor costs for regional pricing differences"
    }
