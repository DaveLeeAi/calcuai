  "metaDescription": "Estimate your body fat percentage using the US Navy circumference method. See your fitness category per ACE standards based on waist, neck, and height.",
  "inputs": [
    {
      "id": "unitSystem",
      "label": "Unit System",
      "type": "radio",
      "required": true,
      "defaultValue": "imperial",
      "options": [
        {
          "value": "imperial",
          "label": "Imperial (inches)"
        },
        {
          "value": "metric",
          "label": "Metric (cm)"
        }
      ]
    },
    {
      "id": "sex",
      "label": "Sex",
      "type": "radio",
      "required": true,
      "defaultValue": "male",
      "options": [
        {
          "value": "male",
          "label": "Male"
        },
        {
          "value": "female",
          "label": "Female"
        }
      ]
    },
    {
      "id": "waist",
      "label": "Waist Circumference",
      "type": "number",
      "required": true,
      "defaultValue": 34,
      "min": 10,
      "max": 80,
      "step": 0.5,
      "helpText": "Measure at navel level (inches or cm)"
    },
    {
      "id": "neck",
      "label": "Neck Circumference",
      "type": "number",
      "required": true,
      "defaultValue": 15,
      "min": 5,
      "max": 35,
      "step": 0.5,
      "helpText": "Measure just below the Adam's apple (inches or cm)"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "required": true,
      "defaultValue": 71,
      "min": 36,
      "max": 108,
      "step": 1,
      "helpText": "Enter height in inches (imperial) or centimeters (metric)"
    },
    {
      "id": "hip",
      "label": "Hip Circumference",
      "type": "number",
      "required": false,
      "defaultValue": 38,
      "min": 15,
      "max": 80,
      "step": 0.5,
      "helpText": "Required for females. Measure at widest point (inches or cm)",
      "dependsOn": "sex"
    }
  ],
  "outputs": [
    {
      "id": "bodyFatPercentage",
      "label": "Body Fat Percentage",
      "type": "single-value",
      "format": "percentage",
      "precision": 1,
      "highlight": true
