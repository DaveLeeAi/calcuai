      "label": "Calculate From",
      "type": "radio",
      "required": true,
      "defaultValue": "fromLMP",
      "options": [
        {
          "value": "fromDueDate",
          "label": "I know my due date"
        },
        {
          "value": "fromLMP",
          "label": "I know my last menstrual period"
        }
      ]
    },
    {
