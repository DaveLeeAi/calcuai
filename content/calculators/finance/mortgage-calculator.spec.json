{
  "id": "mortgage-calculator",
  "title": "Mortgage Calculator",
  "slug": "mortgage-calculator",
  "category": "finance",
  "subcategory": "mortgage",
  "primaryKeyword": "mortgage calculator",
  "metaTitle": "Mortgage Calculator — Free Monthly Payment Calculator",
  "metaDescription": "Calculate your monthly mortgage payment with principal, interest, taxes, and insurance. See your full amortization schedule. Free, no signup required.",
  "inputs": [
    {
      "id": "homePrice",
      "label": "Home Price",
      "type": "currency",
      "required": true,
      "defaultValue": 350000,
      "min": 10000,
      "max": 10000000,
      "step": 1000,
      "prefix": "$"
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "currency",
      "required": true,
      "defaultValue": 70000,
      "min": 0,
      "maxDependency": "homePrice",
      "prefix": "$"
    },
    {
      "id": "downPaymentPercent",
      "label": "Down Payment %",
      "type": "percentage",
      "required": false,
      "defaultValue": 20,
      "min": 0,
      "max": 100,
      "dependsOn": "downPayment",
      "helpText": "Syncs with down payment amount"
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 6.5,
      "min": 0.1,
      "max": 25,
      "step": 0.125
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "select",
      "required": true,
      "defaultValue": "30",
      "options": [
        {
          "value": "10",
          "label": "10 years"
        },
        {
          "value": "15",
          "label": "15 years"
        },
        {
          "value": "20",
          "label": "20 years"
        },
        {
          "value": "30",
          "label": "30 years"
        }
      ]
    },
    {
      "id": "propertyTax",
      "label": "Annual Property Tax",
      "type": "currency",
      "required": false,
      "defaultValue": 3500,
      "min": 0,
      "helpText": "Annual property tax amount"
    },
    {
      "id": "homeInsurance",
      "label": "Annual Home Insurance",
      "type": "currency",
      "required": false,
      "defaultValue": 1200,
      "min": 0
    },
    {
      "id": "includePMI",
      "label": "Include PMI",
      "type": "toggle",
      "required": false,
      "defaultValue": true,
      "helpText": "Private mortgage insurance (required if down payment < 20%)"
    }
  ],
  "outputs": [
    {
      "id": "monthlyPayment",
      "label": "Monthly Payment (PITI)",
      "type": "single-value",
      "format": "currency",
      "highlight": true,
      "description": "Total monthly payment including principal & interest, property tax, home insurance, and PMI if applicable."
    },
    {
      "id": "paymentBreakdown",
      "label": "Monthly Payment Breakdown",
      "type": "chart-pie",
      "description": "How each dollar of your monthly payment is allocated between principal & interest, taxes, insurance, and PMI.",
      "chartConfig": {
        "colors": [
          "#1A6FA0",
          "#2ECC71",
          "#E74C3C",
          "#F39C12"
        ]
      }
    },
    {
      "id": "loanSummary",
      "label": "Loan Cost Summary",
      "type": "value-group",
      "format": "currency",
      "description": "Total amounts paid over the full loan term, including all interest and fees."
    },
    {
      "id": "yearlyBreakdown",
      "label": "Annual Principal vs. Interest",
      "type": "chart-bar",
      "description": "Year-by-year view of how your payments split between reducing principal and paying interest. In early years most of each payment is interest; this flips as the loan matures.",
      "chartConfig": {
        "xLabel": "Year",
        "yLabel": "Amount ($)",
        "colors": [
          "#1A6FA0",
          "#E74C3C"
        ]
      }
    },
    {
      "id": "balanceOverTime",
      "label": "Remaining Balance Over Time",
      "type": "chart-line",
      "description": "How your outstanding loan balance declines year by year as you make regular payments.",
      "chartConfig": {
        "xLabel": "Year",
        "yLabel": "Balance ($)",
        "colors": [
          "#1A6FA0"
        ]
      }
    },
    {
      "id": "amortizationSchedule",
      "label": "Full Amortization Schedule",
      "type": "table",
      "description": "Month-by-month breakdown of every payment showing principal paid, interest charged, and remaining balance.",
      "columns": [
        {
          "key": "month",
          "label": "Month"
        },
        {
          "key": "payment",
          "label": "Payment",
          "format": "currency"
        },
        {
          "key": "principal",
          "label": "Principal",
          "format": "currency"
        },
        {
          "key": "interest",
          "label": "Interest",
          "format": "currency"
        },
        {
          "key": "balance",
          "label": "Remaining Balance",
          "format": "currency"
        }
      ]
    }
  ],
