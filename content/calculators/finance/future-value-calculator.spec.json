      "id": "presentValue",
      "label": "Initial Investment (PV)",
      "type": "currency",
      "required": false,
      "defaultValue": 10000,
      "min": 0,
      "max": 100000000,
      "step": 100,
      "prefix": "$",
      "helpText": "The lump sum you're investing today."
    },
    {
      "id": "periodicPayment",
      "label": "Periodic Contribution",
      "type": "currency",
      "required": false,
      "defaultValue": 0,
      "min": 0,
      "max": 10000000,
      "step": 50,
      "prefix": "$",
