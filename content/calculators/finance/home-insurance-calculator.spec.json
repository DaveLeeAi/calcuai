{
  "id": "home-insurance-calculator",
  "title": "Home Insurance Calculator",
  "slug": "home-insurance-calculator",
  "category": "finance",
  "subcategory": "mortgage",
  "primaryKeyword": "home insurance calculator",
  "metaTitle": "Home Insurance Calculator | Estimate Annual Homeowners Insurance",
  "metaDescription": "Estimate your annual homeowners insurance premium based on home value, state, deductible, and coverage type. Compare costs by state with 2025 rates.",
  "inputs": [
    {
      "id": "homeValue",
      "label": "Home Value",
      "type": "currency",
      "required": true,
      "defaultValue": 300000,
      "min": 0,
      "max": 10000000,
      "step": 5000,
      "prefix": "$",
      "helpText": "Home replacement cost / dwelling coverage amount"
    },
    {
      "id": "state",
      "label": "State",
      "type": "select",
      "required": true,
      "defaultValue": "other",
      "options": [
        {
          "value": "TX",
          "label": "Texas"
        },
        {
          "value": "FL",
          "label": "Florida"
        },
        {
          "value": "OK",
          "label": "Oklahoma"
        },
        {
          "value": "KS",
          "label": "Kansas"
        },
        {
          "value": "CO",
          "label": "Colorado"
        },
        {
          "value": "LA",
          "label": "Louisiana"
        },
        {
          "value": "MN",
          "label": "Minnesota"
        },
        {
          "value": "CT",
          "label": "Connecticut"
        },
        {
          "value": "NE",
          "label": "Nebraska"
        },
        {
          "value": "other",
          "label": "Other / National Average"
        }
      ],
      "helpText": "State affects base rate"
    },
    {
      "id": "deductible",
      "label": "Deductible",
      "type": "select",
      "required": true,
      "defaultValue": "1000",
      "options": [
        {
          "value": "500",
          "label": "$500"
        },
        {
          "value": "1000",
          "label": "$1,000"
        },
        {
          "value": "2000",
          "label": "$2,000"
        },
        {
          "value": "2500",
          "label": "$2,500"
        },
        {
          "value": "5000",
          "label": "$5,000"
        }
      ]
    },
    {
      "id": "coverageType",
      "label": "Coverage Type",
      "type": "select",
      "required": true,
      "defaultValue": "standard",
      "options": [
        {
          "value": "basic",
          "label": "HO-1 Basic"
        },
        {
          "value": "standard",
          "label": "HO-3 Standard"
        },
        {
          "value": "premium",
          "label": "HO-5 Premium"
        }
      ],
      "helpText": "HO-1 basic, HO-3 standard, HO-5 premium"
    },
    {
      "id": "claimsHistory",
      "label": "Claims in Past 5 Years",
      "type": "select",
      "required": true,
      "defaultValue": "0",
      "options": [
        {
          "value": "0",
          "label": "0 claims"
        },
        {
          "value": "1",
          "label": "1 claim"
        },
        {
          "value": "2+",
          "label": "2+ claims"
        }
      ],
      "helpText": "Number of claims in past 5 years"
    },
    {
      "id": "creditScore",
      "label": "Credit Score Range",
      "type": "select",
      "required": true,
      "defaultValue": "good",
      "options": [
        {
          "value": "excellent",
          "label": "Excellent (750+)"
        },
        {
          "value": "good",
          "label": "Good (670–749)"
        },
        {
          "value": "fair",
          "label": "Fair (580–669)"
        },
        {
          "value": "poor",
          "label": "Poor (below 580)"
        }
      ],
      "helpText": "Credit-based insurance score affects premium"
    }
  ],
  "outputs": [
    {
      "id": "annualPremium",
      "label": "Estimated Annual Premium",
      "type": "single-value",
      "format": "currency",
      "highlight": true
    },
    {
      "id": "monthlyPremium",
      "label": "Monthly Cost",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "dailyPremium",
      "label": "Daily Cost",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "dwellingCoverage",
      "label": "Dwelling Coverage",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "personalProperty",
      "label": "Personal Property Coverage",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "liabilityCoverage",
      "label": "Liability Coverage",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "baseRate",
      "label": "Base Rate (per $1,000)",
      "type": "single-value",
      "format": "currency",
      "precision": 2
    },
    {
      "id": "costBreakdown",
      "label": "Cost Breakdown",
      "type": "value-group",
      "format": "currency"
    },
    {
      "id": "coverageSummary",
      "label": "Coverage Summary",
      "type": "value-group",
      "format": "currency"
    },
    {
      "id": "coverageBreakdownChart",
      "label": "Coverage Breakdown",
      "type": "chart-pie",
      "description": "Visual split of your total homeowners insurance coverage by category.",
      "chartConfig": {
        "colors": [
          "#1A6FA0",
          "#27AE60",
          "#E74C3C",
          "#F39C12"
        ]
      }
    }
  ],
  "formula": "home-insurance",
  "features": [
    "shareable-url",
