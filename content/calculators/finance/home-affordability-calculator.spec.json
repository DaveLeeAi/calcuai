  "metaTitle": "Home Affordability Calculator — How Much House Can You Afford?",
  "metaDescription": "Calculate how much house you can afford using the 28/36 rule. Enter income, debts, and down payment to see your max home price, payment, and DTI ratios.",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Household Income",
      "type": "currency",
      "required": true,
      "defaultValue": 100000,
      "min": 0,
      "max": 10000000,
      "step": 1000,
      "prefix": "$"
    },
    {
      "id": "monthlyDebts",
      "label": "Monthly Debt Payments",
      "type": "currency",
      "required": true,
      "defaultValue": 500,
      "min": 0,
      "max": 100000,
      "step": 50,
      "prefix": "$",
      "helpText": "Total monthly payments for car loans, student loans, credit cards, etc. (excluding housing)."
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "currency",
      "required": true,
      "defaultValue": 60000,
      "min": 0,
      "max": 10000000,
      "step": 1000,
      "prefix": "$"
    },
    {
      "id": "interestRate",
      "label": "Mortgage Interest Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 6.5,
      "min": 0,
      "max": 15,
      "step": 0.125,
      "helpText": "Current 30-year fixed mortgage rates. Check Freddie Mac PMMS for this week's average."
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "select",
      "required": true,
      "defaultValue": "30",
      "options": [
        {
          "value": "15",
          "label": "15 Years"
        },
        {
          "value": "20",
          "label": "20 Years"
        },
        {
          "value": "30",
          "label": "30 Years"
        }
      ]
    },
    {
      "id": "propertyTaxRate",
      "label": "Property Tax Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 1.2,
      "min": 0,
      "max": 5,
      "step": 0.1,
      "helpText": "Annual property tax rate. U.S. average: ~1.1%. Varies by state and county."
    },
    {
      "id": "annualInsurance",
      "label": "Annual Homeowner's Insurance",
      "type": "currency",
      "required": true,
      "defaultValue": 1500,
      "min": 0,
      "max": 20000,
      "step": 100,
      "prefix": "$",
      "helpText": "U.S. average: ~$1,500/year."
    },
    {
      "id": "includePMI",
      "label": "Include PMI",
      "type": "toggle",
      "required": false,
      "defaultValue": true,
      "helpText": "Private mortgage insurance is required when down payment is less than 20%."
    }
