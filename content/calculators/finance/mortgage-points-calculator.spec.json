  "metaTitle": "Mortgage Points Calculator | Should You Buy Discount Points?",
  "metaDescription": "Calculate if buying mortgage points is worth it. See your break-even timeline, monthly savings, and total interest saved over the life of the loan.",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "currency",
      "required": true,
      "defaultValue": 300000,
      "min": 0,
      "max": 5000000,
      "step": 1000,
      "prefix": "$"
    },
    {
      "id": "interestRate",
      "label": "Current Interest Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 7,
      "min": 0,
      "max": 30,
      "step": 0.125,
      "suffix": "%"
    },
    {
      "id": "pointsPurchased",
      "label": "Points to Buy",
      "type": "number",
      "required": true,
      "defaultValue": 1,
      "min": 0,
      "max": 5,
      "step": 0.25,
      "helpText": "Number of discount points to buy. Each point costs 1% of the loan amount."
    },
    {
      "id": "rateReductionPerPoint",
      "label": "Rate Reduction per Point",
      "type": "percentage",
      "required": true,
      "defaultValue": 0.25,
      "min": 0.1,
      "max": 0.5,
      "step": 0.05,
      "suffix": "%",
      "helpText": "How much each point reduces your interest rate. Typically 0.25%."
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "select",
      "required": true,
      "defaultValue": "30",
      "options": [
        { "value": "15", "label": "15 Years" },
        { "value": "30", "label": "30 Years" }
      ]
    }
  ],
  "outputs": [
    {
      "id": "pointsCost",
      "label": "Cost of Points",
      "type": "single-value",
      "format": "currency",
      "description": "Upfront cost to buy discount points (each point = 1% of loan)."
    },
    {
      "id": "monthlySavings",
      "label": "Monthly Savings",
      "type": "single-value",
      "format": "currency",
      "highlight": true,
      "description": "How much less you pay each month after buying points."
    },
    {
      "id": "breakEvenMonths",
      "label": "Break-Even Time",
      "type": "single-value",
      "format": "number",
      "description": "Months until monthly savings recoup the upfront cost."
    },
    {
      "id": "breakEvenYears",
      "label": "Break-Even (Years)",
      "type": "single-value",
      "format": "number",
      "precision": 1,
      "description": "Break-even timeline in years."
    },
    {
      "id": "newPayment",
      "label": "New Monthly Payment",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "originalPayment",
      "label": "Original Monthly Payment",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "totalSavingsOverLoan",
      "label": "Net Savings Over Loan",
      "type": "single-value",
      "format": "currency",
      "description": "Total interest saved minus the cost of points."
