    {
      "id": "interestSaved",
      "label": "Total Interest Saved",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "roi",
      "label": "Return on Investment",
      "type": "single-value",
      "format": "percentage",
      "precision": 1
    },
    {
      "id": "newRate",
      "label": "New Interest Rate",
      "type": "single-value",
      "format": "percentage",
