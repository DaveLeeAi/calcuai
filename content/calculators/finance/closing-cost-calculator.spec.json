      "type": "percentage",
      "required": true,
      "defaultValue": 20,
      "min": 0,
      "max": 100,
      "step": 0.5,
      "helpText": "Percentage of home price. Less than 20% triggers PMI on conventional loans."
    },
    {
      "id": "loanType",
      "label": "Loan Type",
      "type": "select",
      "required": true,
      "defaultValue": "conventional",
      "options": [
        {
          "value": "conventional",
          "label": "Conventional"
        },
        {
          "value": "fha",
          "label": "FHA"
        },
        {
          "value": "va",
          "label": "VA"
        }
      ],
      "helpText": "FHA adds 1.75% upfront MIP. VA adds 2.3% funding fee."
    },
    {
      "id": "isNewConstruction",
      "label": "New Construction",
      "type": "toggle",
      "required": false,
      "defaultValue": false,
