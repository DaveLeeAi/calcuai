{
  "id": "loan-calculator",
  "title": "Loan Calculator",
  "slug": "loan-calculator",
  "category": "finance",
  "subcategory": "loans",
  "primaryKeyword": "loan calculator",
  "metaTitle": "Loan Calculator — Free Payment & Amortization Tool",
  "metaDescription": "Calculate your monthly loan payment, total interest, and full amortization schedule. Compare payoff strategies with extra payments. Free, instant results.",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "currency",
      "required": true,
      "defaultValue": 25000,
      "min": 100,
      "max": 10000000,
      "step": 100,
      "prefix": "$"
    },
    {
      "id": "annualRate",
      "label": "Interest Rate (APR)",
      "type": "percentage",
      "required": true,
      "defaultValue": 6.5,
      "min": 0,
      "max": 36,
      "step": 0.1,
      "helpText": "Your annual interest rate (APR)"
    },
    {
      "id": "loanTerm",
      "label": "Loan Term (Months)",
      "type": "number",
      "required": true,
      "defaultValue": 60,
      "min": 1,
      "max": 360,
      "step": 1,
      "helpText": "Loan term in months (e.g., 60 = 5 years)"
    },
    {
      "id": "extraPayment",
      "label": "Extra Monthly Payment",
      "type": "currency",
      "required": false,
      "defaultValue": 0,
      "min": 0,
      "max": 100000,
      "step": 10,
      "prefix": "$",
      "helpText": "Optional extra monthly payment toward principal"
    }
  ],
  "outputs": [
    {
      "id": "monthlyPayment",
      "label": "Monthly Payment",
      "type": "single-value",
      "format": "currency",
      "highlight": true,
      "description": "Base monthly payment of principal and interest. Does not include insurance or taxes."
    },
    {
      "id": "paymentBreakdown",
      "label": "Principal vs. Total Interest",
      "type": "chart-pie",
      "description": "Proportion of your total payments that goes to paying back the original loan versus the cost of borrowing.",
      "chartConfig": {
        "colors": [
          "#1A6FA0",
          "#E74C3C"
        ]
      }
    },
    {
      "id": "summary",
      "label": "Loan Cost Summary",
      "type": "value-group",
      "format": "currency",
      "description": "Key totals over the life of the loan. If extra payments are entered, savings are shown here."
    },
    {
      "id": "yearlyBreakdown",
      "label": "Annual Principal vs. Interest",
      "type": "chart-bar",
      "description": "How your payments split between principal reduction and interest each year. Extra payments shift this ratio toward principal.",
      "chartConfig": {
        "xLabel": "Year",
        "yLabel": "Amount ($)",
        "colors": [
          "#1A6FA0",
          "#E74C3C"
        ]
      }
    },
    {
      "id": "balanceOverTime",
      "label": "Loan Balance Over Time",
      "type": "chart-line",
      "description": "Remaining balance month by month. When extra payments are applied, a second line shows the faster payoff trajectory.",
      "chartConfig": {
        "xLabel": "Month",
        "yLabel": "Balance ($)",
        "colors": [
          "#1A6FA0",
          "#2ECC71"
        ]
      }
    },
    {
      "id": "amortizationSchedule",
      "label": "Full Amortization Schedule",
      "type": "table",
      "description": "Every payment listed month by month with the principal, interest, any extra payment applied, and remaining balance.",
      "columns": [
        {
          "key": "month",
          "label": "Month"
        },
        {
          "key": "payment",
          "label": "Payment",
          "format": "currency"
        },
        {
          "key": "principal",
          "label": "Principal",
          "format": "currency"
        },
        {
          "key": "interest",
          "label": "Interest",
          "format": "currency"
        },
        {
          "key": "extraPayment",
          "label": "Extra",
          "format": "currency"
        },
        {
          "key": "balance",
          "label": "Balance",
          "format": "currency"
        }
      ]
    }
  ],
  "formula": "loan-payment",
  "features": [
    "chart",
    "amortization-table",
    "compare-scenarios",
    "shareable-url",
    "print-results"
  ],
  "tabs": [
    {
