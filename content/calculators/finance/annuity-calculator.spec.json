  "metaTitle": "Annuity Calculator — Free Payment, PV & FV Annuity Calculator",
  "metaDescription": "Calculate annuity payments, present value, or future value. Compare ordinary annuity vs annuity due. Monthly or annual payments. Free, no signup required.",
  "inputs": [
    {
      "id": "mode",
      "label": "Solve For",
      "type": "select",
      "required": true,
      "defaultValue": "pv-to-payment",
      "options": [
        {
          "value": "pv-to-payment",
          "label": "Payment from Present Value (Loan/Payout)"
        },
        {
          "value": "fv-to-payment",
          "label": "Payment from Future Value (Savings Goal)"
        },
        {
          "value": "payment-to-pv",
          "label": "Present Value from Payment"
        },
        {
          "value": "payment-to-fv",
          "label": "Future Value from Payment"
        }
      ],
      "helpText": "Choose what you want to calculate."
    },
    {
      "id": "timing",
      "label": "Annuity Type",
      "type": "select",
      "required": true,
      "defaultValue": "ordinary",
      "options": [
        {
          "value": "ordinary",
          "label": "Ordinary Annuity (end of period)"
        },
        {
          "value": "due",
          "label": "Annuity Due (start of period)"
        }
      ],
      "helpText": "Ordinary = payments at end of period. Due = payments at start."
    },
    {
      "id": "presentValue",
      "label": "Present Value",
      "type": "currency",
      "required": false,
      "defaultValue": 100000,
      "min": 0,
      "max": 100000000,
      "step": 1000,
      "prefix": "$",
      "helpText": "Used in PV-to-Payment and Payment-to-PV modes."
    },
    {
      "id": "futureValue",
      "label": "Future Value",
      "type": "currency",
      "required": false,
      "defaultValue": 500000,
      "min": 0,
      "max": 100000000,
      "step": 1000,
      "prefix": "$",
      "helpText": "Used in FV-to-Payment and Payment-to-FV modes."
    },
    {
      "id": "paymentAmount",
      "label": "Payment Amount",
      "type": "currency",
      "required": false,
      "defaultValue": 1000,
      "min": 0,
      "max": 10000000,
      "step": 50,
      "prefix": "$",
      "helpText": "Used in Payment-to-PV and Payment-to-FV modes."
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 5,
      "min": 0,
      "max": 30,
      "step": 0.1
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "required": true,
      "defaultValue": 20,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "id": "paymentsPerYear",
      "label": "Payments Per Year",
      "type": "select",
      "required": true,
      "defaultValue": "12",
      "options": [
        {
          "value": "1",
          "label": "Annually (1)"
        },
        {
          "value": "2",
          "label": "Semi-Annually (2)"
        },
        {
          "value": "4",
          "label": "Quarterly (4)"
        },
        {
          "value": "12",
          "label": "Monthly (12)"
        },
        {
          "value": "26",
          "label": "Bi-Weekly (26)"
        },
        {
          "value": "52",
          "label": "Weekly (52)"
        }
      ]
    }
