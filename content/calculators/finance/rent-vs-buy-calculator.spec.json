{
  "id": "rent-vs-buy-calculator",
  "title": "Rent vs Buy Calculator",
  "slug": "rent-vs-buy-calculator",
  "category": "finance",
  "subcategory": "mortgage",
  "primaryKeyword": "rent vs buy calculator",
  "metaTitle": "Rent vs Buy Calculator — Compare Total Cost Over Time",
  "metaDescription": "Should you rent or buy? Compare the true cost of renting vs buying a home over 1-30 years. Includes equity, appreciation, PMI, taxes, and opportunity cost.",
  "inputs": [
    {
      "id": "homePrice",
      "label": "Home Price",
      "type": "currency",
      "required": true,
      "defaultValue": 400000,
      "min": 10000,
      "max": 100000000,
      "prefix": "$"
    },
    {
      "id": "downPaymentPercent",
      "label": "Down Payment",
      "type": "percentage",
      "required": true,
      "defaultValue": 20,
      "min": 0,
      "max": 100,
      "step": 0.5,
      "helpText": "Percentage of home price"
    },
    {
      "id": "interestRate",
      "label": "Mortgage Interest Rate",
      "type": "percentage",
      "required": true,
      "defaultValue": 6.5,
      "min": 0,
      "max": 15,
      "step": 0.125,
      "helpText": "Annual mortgage interest rate"
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "select",
      "required": true,
      "defaultValue": "30",
      "options": [
        {
          "value": "15",
          "label": "15 Years"
        },
        {
          "value": "30",
          "label": "30 Years"
        }
      ]
    },
    {
      "id": "monthlyRent",
      "label": "Monthly Rent",
      "type": "currency",
      "required": true,
      "defaultValue": 2000,
      "min": 0,
      "max": 100000,
      "prefix": "$"
    },
    {
      "id": "annualRentIncrease",
      "label": "Annual Rent Increase",
      "type": "percentage",
      "required": false,
      "defaultValue": 3,
      "min": 0,
      "max": 15,
      "step": 0.5,
      "helpText": "Expected annual rent increase (national average ~3%)"
    },
    {
      "id": "propertyTaxRate",
      "label": "Property Tax Rate",
      "type": "percentage",
      "required": false,
      "defaultValue": 1.2,
      "min": 0,
      "max": 5,
      "step": 0.1,
      "helpText": "Annual property tax as % of home value"
    },
    {
      "id": "annualInsurance",
      "label": "Annual Home Insurance",
      "type": "currency",
      "required": false,
      "defaultValue": 1500,
      "min": 0,
      "max": 50000,
      "prefix": "$"
    },
    {
      "id": "annualMaintenance",
      "label": "Annual Maintenance",
      "type": "percentage",
      "required": false,
      "defaultValue": 1,
      "min": 0,
      "max": 5,
      "step": 0.1,
      "helpText": "Annual maintenance cost as % of home value"
    },
    {
      "id": "homeAppreciation",
      "label": "Home Appreciation Rate",
      "type": "percentage",
      "required": false,
      "defaultValue": 3,
      "min": -5,
      "max": 15,
      "step": 0.5,
      "helpText": "Expected annual home value appreciation"
    },
    {
      "id": "investmentReturn",
      "label": "Investment Return Rate",
      "type": "percentage",
      "required": false,
      "defaultValue": 7,
      "min": 0,
      "max": 20,
      "step": 0.5,
      "helpText": "Expected return if you invest the down payment instead"
    },
    {
      "id": "yearsToCompare",
      "label": "Years to Compare",
      "type": "number",
      "required": true,
      "defaultValue": 10,
      "min": 1,
      "max": 30,
      "step": 1,
      "helpText": "How many years to compare renting vs buying"
    }
  ],
  "outputs": [
    {
      "id": "recommendation",
      "label": "Recommendation",
      "type": "single-value",
      "format": "text",
      "highlight": true
    },
    {
      "id": "totalRentCost",
      "label": "Net Cost of Renting",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "totalBuyCost",
      "label": "Net Cost of Buying",
      "type": "single-value",
      "format": "currency"
    },
    {
      "id": "breakEvenYear",
      "label": "Break-Even Year",
      "type": "single-value",
      "format": "number"
    },
    {
      "id": "summary",
      "label": "Comparison Summary",
      "type": "value-group"
    },
    {
      "id": "costComparison",
      "label": "Net Cost Over Time",
      "type": "chart-line",
      "chartConfig": {
        "xLabel": "Year",
        "yLabel": "Net Cost ($)",
        "colors": [
          "#E74C3C",
          "#2ECC71"
        ]
      }
    },
    {
      "id": "yearByYear",
      "label": "Year-by-Year Comparison",
      "type": "table",
      "columns": [
        {
          "key": "year",
          "label": "Year"
        },
        {
          "key": "rentTotal",
          "label": "Rent Net Cost",
          "format": "currency"
        },
        {
          "key": "buyTotal",
          "label": "Buy Net Cost",
          "format": "currency"
        },
        {
          "key": "difference",
          "label": "Difference",
          "format": "currency"
        }
      ]
    }
  ],
  "formula": "rent-vs-buy",
  "features": [
    "chart",
    "compare-scenarios"
  ],
  "relatedCalculators": [
